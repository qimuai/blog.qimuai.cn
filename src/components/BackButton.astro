---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
---

{
  SITE.showBackButton && (
    <div
      id="back-button-wrap"
      class="app-layout flex hidden items-center justify-start"
      aria-hidden="true"
    >
      <LinkButton
        id="back-button"
        href="/"
        class="focus-outline -ms-1 mt-6 mb-1 text-sm text-foreground/38 hover:text-foreground/70"
      >
        <IconChevronLeft class="inline-block size-4 rtl:rotate-180" />
        <span>返回</span>
      </LinkButton>
    </div>
  )
}

<script>
  /* Update Search Praam */
  function updateGoBackUrl() {
    const backButton: HTMLAnchorElement | null =
      document.querySelector("#back-button");
    const backButtonWrap: HTMLDivElement | null =
      document.querySelector("#back-button-wrap");

    const backUrl = sessionStorage.getItem("backUrl");

    const shouldShowBackButton =
      !!backUrl &&
      backUrl !== "/" &&
      backUrl !== window.location.pathname &&
      backUrl !== window.location.pathname + window.location.search;

    if (shouldShowBackButton && backUrl && backButton && backButtonWrap) {
      backButton.href = backUrl;
      backButtonWrap.classList.remove("hidden");
      backButtonWrap.setAttribute("aria-hidden", "false");
      return;
    }

    backButtonWrap?.classList.add("hidden");
    backButtonWrap?.setAttribute("aria-hidden", "true");
  }

  document.addEventListener("astro:page-load", updateGoBackUrl);
  updateGoBackUrl();
</script>
