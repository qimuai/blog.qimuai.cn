---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const latestPost = sortedPosts.at(0);
const uniqueTags = new Set(sortedPosts.flatMap(({ data }) => data.tags));
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="wide-layout">
    <section id="hero" class:list={["pt-8 pb-10", "border-b border-border/70"]}>
      <p class="section-kicker">blog.qimuai.cn</p>
      <div
        class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,1.5fr)_minmax(260px,0.8fr)]"
      >
        <div>
          <h1
            class="max-w-4xl font-display text-5xl leading-[1.08] font-semibold sm:text-6xl lg:text-7xl"
          >
            把复杂问题写清楚，把真实经验留下来。
          </h1>
          <p
            class="mt-6 max-w-2xl text-base leading-8 text-foreground/80 sm:text-lg"
          >
            这里记录 AI 应用、自动化工作流、Web 工程和产品实践，
            重点不是概念，而是那些真正在线上跑通的细节。
          </p>
          <div
            class="mt-6 grid max-w-3xl gap-3 text-sm leading-7 text-foreground/72 sm:grid-cols-3"
          >
            <div class="paper-panel p-4">
              <div class="section-kicker">写作准则</div>
              <p class="mt-3">只写亲手做过、真正在生产或协作里验证过的内容。</p>
            </div>
            <div class="paper-panel p-4">
              <div class="section-kicker">偏好主题</div>
              <p class="mt-3">AI 工具链、自动化流程、内容系统、部署与复盘。</p>
            </div>
            <div class="paper-panel p-4">
              <div class="section-kicker">更新方式</div>
              <p class="mt-3">本地写作，推送 GitHub，自动发布到腾讯云。</p>
            </div>
          </div>
          <div class="mt-7 flex flex-wrap gap-4">
            <LinkButton href="/posts/">
              开始阅读
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
            <LinkButton href="/about/" class="opacity-80">
              了解这个博客
            </LinkButton>
          </div>
        </div>

        <aside class="paper-panel p-5">
          <div class="section-kicker">站点状态</div>
          <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-1">
            <div class="border-b border-border/60 pb-3">
              <div class="text-foreground/56">文章数量</div>
              <div class="mt-1 font-display text-3xl">{sortedPosts.length}</div>
            </div>
            <div class="border-b border-border/60 pb-3">
              <div class="text-foreground/56">主题标签</div>
              <div class="mt-1 font-display text-3xl">{uniqueTags.size}</div>
            </div>
            <div class="border-b border-border/60 pb-3">
              <div class="text-foreground/56">最近更新</div>
              <div class="mt-1 text-base">
                {latestPost?.data.title ?? "准备中"}
              </div>
            </div>
            <div>
              <div class="text-foreground/56">发布链路</div>
              <div class="mt-1 text-base">GitHub Actions 已接通</div>
            </div>
          </div>
        </aside>
      </div>

      {
        SOCIALS.length > 0 && (
          <div class="mt-8 flex flex-wrap items-center gap-3 text-sm">
            <span class="section-kicker">相关链接</span>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border/70": recentPosts.length > 0 },
          ]}
        >
          <p class="section-kicker">Editor's Pick</p>
          <h2 class="mt-3 font-display text-3xl font-semibold tracking-wide">
            置顶文章
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <p class="section-kicker">Recent Notes</p>
          <h2 class="mt-3 font-display text-3xl font-semibold tracking-wide">
            最新更新
          </h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-10 text-center">
      <LinkButton href="/posts/">
        查看全部文章
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
