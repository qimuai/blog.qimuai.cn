---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-8 sm:py-6",
      "border-t border-border",
      "flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between",
    ]}
  >
    <div class="order-2 sm:order-1">
      <div class="flex flex-wrap items-center gap-3 text-sm text-foreground/70">
        <span>&#169; {currentYear} Qimuai Blog</span>
        <span>写给自己，也写给后来的人。</span>
      </div>
      <div
        class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-foreground/56"
      >
        <a href="/rss.xml" class="hover:text-accent">RSS</a>
        <a href="/sitemap-index.xml" class="hover:text-accent">Sitemap</a>
        <span id="busuanzi_container_site_pv" style="display:none;">
          总访问 <span id="busuanzi_value_site_pv"></span>
        </span>
        <span id="busuanzi_container_site_uv" style="display:none;">
          独立访客 <span id="busuanzi_value_site_uv"></span>
        </span>
      </div>
    </div>
    <div class="order-1 sm:order-2">
      <p class="mb-3 section-kicker">连接</p>
      <Socials />
    </div>
  </div>
</footer>
