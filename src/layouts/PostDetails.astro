---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import GiscusComments from "@/components/GiscusComments.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import getReadingStats from "@/utils/getReadingStats";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content, headings = [] } = await render(post);
const readingStats = getReadingStats(post.body ?? "");
const pagePath = getPath(post.id, post.filePath);
const pageUrl = new URL(pagePath, Astro.site).href;
const siteHost = new URL(SITE.website).hostname;
const leadTag = tags.at(0) ?? "文章";
const tocHeadings = headings.filter(({ depth }) => depth >= 2 && depth <= 3);
const contentWidthClass = "max-w-[50rem]";

const formattedMetaDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: timezone || SITE.timezone,
}).format(new Date(pubDatetime));

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${pagePath}/index.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

const allPosts = posts.map(item => ({
  ...item,
  path: getPath(item.id, item.filePath),
}));

const currentPostIndex = allPosts.findIndex(item => item.id === post.id);
const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;

const relatedPosts = allPosts
  .filter(item => item.id !== post.id)
  .map(item => {
    const sharedTags = item.data.tags.filter(tag => tags.includes(tag));

    return {
      ...item,
      sharedTags,
      sharedScore: sharedTags.length,
    };
  })
  .filter(item => item.sharedScore > 0)
  .sort((a, b) => {
    const tagDiff = b.sharedScore - a.sharedScore;
    if (tagDiff !== 0) return tagDiff;

    return (
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
    );
  })
  .slice(0, 5);
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={[
      "wide-layout pb-16 xl:max-w-[88rem] 2xl:max-w-[92rem]",
      { "mt-10": !SITE.showBackButton, "mt-4": SITE.showBackButton },
    ]}
    data-pagefind-body
  >
    <div
      class="grid gap-10 xl:grid-cols-[16rem_minmax(0,50rem)] xl:gap-24 2xl:grid-cols-[17rem_minmax(0,52rem)] 2xl:gap-28"
    >
      <aside
        class="hidden xl:sticky xl:top-28 xl:block xl:self-start xl:pt-24"
        data-pagefind-ignore
      >
        <TableOfContents headings={tocHeadings} />
      </aside>

      <div class="min-w-0">
        <header
          class:list={[contentWidthClass, "border-b border-border/45 pb-6"]}
        >
          <div
            class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[0.72rem] tracking-[0.24em] text-foreground/34 uppercase"
          >
            <span>{leadTag}</span>
            <span class="text-foreground/18">/</span>
            <span>{siteHost}</span>
          </div>
          <h1
            transition:name={slugifyStr(title.replaceAll(".", "-"))}
            class="mt-4 font-display text-[2.45rem] leading-[1.08] font-medium tracking-[-0.02em] text-foreground sm:text-[3.4rem]"
          >
            {title}
          </h1>
          <div
            class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-foreground/48 sm:text-[0.98rem]"
          >
            <span>{author}</span>
            <span class="text-foreground/20">·</span>
            <time datetime={new Date(pubDatetime).toISOString()}>
              {formattedMetaDate}
            </time>
            <span class="text-foreground/20">·</span>
            <span>{siteHost}</span>
            <span class="text-foreground/20">·</span>
            <span>约 {readingStats.readingMinutes} 分钟</span>
            <span class="text-foreground/20">·</span>
            <span>{readingStats.wordCount} 字</span>
            <span class="text-foreground/20">·</span>
            <span id="busuanzi_container_page_pv" style="display:none;">
              本文阅读 <span id="busuanzi_value_page_pv"></span> 次
            </span>
            <span id="page-pv-fallback">统计加载中</span>
          </div>
        </header>

        <article
          id="article"
          class:list={[
            "app-prose mt-10 w-full prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)",
            contentWidthClass,
          ]}
        >
          <Content />
        </article>

        <section
          class:list={[
            contentWidthClass,
            "mt-10 border-t border-border/42 pt-5",
          ]}
        >
          <ul class="flex flex-wrap gap-3">
            {
              tags.map(tag => (
                <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
              ))
            }
          </ul>

          <div
            class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-foreground/48"
          >
            <EditPost {hideEditPost} {post} />
            <ShareLinks />
          </div>
        </section>

        {
          relatedPosts.length > 0 && (
            <section
              class:list={[
                contentWidthClass,
                "mt-12 border-t border-border/34 pt-5",
              ]}
              data-pagefind-ignore
            >
              <div class="flex flex-wrap items-center justify-between gap-3">
                <p class="text-[0.68rem] tracking-[0.28em] text-foreground/34 uppercase">
                  同标签继续读
                </p>
                <LinkButton
                  href="/"
                  class="text-sm text-foreground/42 hover:text-foreground"
                >
                  <IconChevronLeft class="inline-block size-4 rtl:rotate-180" />
                  回到首页
                </LinkButton>
              </div>

              <ul class="mt-4 space-y-2.5">
                {relatedPosts.map(item => (
                  <li>
                    <a
                      href={item.path}
                      class="group flex items-baseline justify-between gap-4 text-sm text-foreground/48 transition-colors hover:text-foreground"
                    >
                      <span class="truncate">{item.data.title}</span>
                      <span class="hidden text-xs text-foreground/28 sm:inline">
                        {item.sharedTags.slice(0, 2).join(" · ")}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <div
          class:list={[
            contentWidthClass,
            "mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-border/28 pt-4 text-sm text-foreground/38",
          ]}
          data-pagefind-ignore
        >
          {
            prevPost && (
              <a href={prevPost.path} class="hover:text-foreground">
                上一篇：{prevPost.data.title}
              </a>
            )
          }
          {
            nextPost && (
              <a href={nextPost.path} class="hover:text-foreground">
                下一篇：{nextPost.data.title}
              </a>
            )
          }
        </div>

        <div class={contentWidthClass}>
          <GiscusComments
            pagePath={pagePath}
            pageTitle={title}
            pageUrl={pageUrl}
          />
        </div>
      </div>
    </div>

    <BackToTopButton />
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const myBar = document.getElementById("myBar");

      if (myBar) {
        myBar.style.width = scrolled + "%";
      }
    });
  }
  updateScrollProgress();

  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );

    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  function syncActiveTocLink() {
    const links = Array.from(document.querySelectorAll("[data-toc-link]"));
    const headings = Array.from(
      document.querySelectorAll("#article h2[id], #article h3[id]")
    );

    if (!links.length || !headings.length) return;

    const setActive = id => {
      for (const link of links) {
        link.setAttribute(
          "data-active",
          link.getAttribute("data-toc-link") === id ? "true" : "false"
        );
      }
    };

    setActive(headings[0].id);

    const observer = new IntersectionObserver(
      entries => {
        const visibleHeadings = entries
          .filter(entry => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visibleHeadings.length > 0) {
          setActive(visibleHeadings[0].target.id);
        }
      },
      {
        rootMargin: "-18% 0px -65% 0px",
        threshold: [0, 1],
      }
    );

    for (const heading of headings) {
      observer.observe(heading);
    }

    document.addEventListener(
      "astro:before-swap",
      () => observer.disconnect(),
      { once: true }
    );
  }
  syncActiveTocLink();

  function attachCopyButtons() {
    const copyButtonLabel = "复制";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      button.innerText = "已复制";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  function syncPageViews() {
    const fallback = document.getElementById("page-pv-fallback");
    const value = document.getElementById("busuanzi_value_page_pv");

    if (!fallback || !value) return;

    let attempts = 0;
    const timer = window.setInterval(() => {
      const ready = Boolean(value.textContent?.trim());
      fallback.toggleAttribute("hidden", ready);
      attempts += 1;

      if (ready || attempts > 20) {
        window.clearInterval(timer);
      }
    }, 250);
  }
  syncPageViews();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
