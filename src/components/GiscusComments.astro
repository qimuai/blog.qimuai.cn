---
import { SITE } from "@/config";
import discussions from "@/data/discussions.json";

type Props = {
  pagePath: string;
  pageTitle: string;
  pageUrl: string;
};

const comments = SITE.comments;
const { pagePath, pageTitle, pageUrl } = Astro.props;
const discussionMap = discussions as Record<
  string,
  { number: number; title: string; url: string }
>;
const discussion = discussionMap[pagePath];
const discussionUrl =
  discussion?.url ??
  `https://github.com/${comments.repo}/discussions/new?category=general&title=${encodeURIComponent(
    `[ ${pagePath} ] ${pageTitle}`
  )}&body=${encodeURIComponent(
    `文章地址: ${pageUrl}\n\n欢迎继续补充案例、问题、勘误和后续实践。`
  )}`;
const discussionLabel = discussion ? "进入文章讨论" : "新建文章讨论";
---

{
  comments.enabled && (
    <section class="mt-16 border-t border-border/70 pt-10">
      <div class="paper-panel p-6 sm:p-8">
        <p class="section-kicker">讨论区</p>
        <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 class="font-display text-2xl leading-tight text-foreground sm:text-3xl">
              继续把这篇文章讨论下去
            </h2>
            <p class="mt-2 max-w-2xl text-sm leading-7 text-foreground/72 sm:text-base">
              当前评论通过 GitHub Discussions 进行。点击下方按钮后，登录 GitHub
              就可以直接在这篇文章的专属讨论帖里留言。
            </p>
          </div>
          <a
            href={`https://github.com/${comments.repo}/discussions`}
            class="text-sm text-accent underline decoration-dashed underline-offset-4"
          >
            打开 Discussions
          </a>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={discussionUrl}
            class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm text-foreground transition-colors hover:border-accent hover:text-accent"
          >
            {discussionLabel}
          </a>
          <a
            href={`https://github.com/${comments.repo}/discussions`}
            class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm text-foreground/72 transition-colors hover:border-accent hover:text-accent"
          >
            查看全部讨论
          </a>
        </div>

        {discussion?.url && (
          <p class="mt-4 text-xs leading-6 text-foreground/56">
            已为这篇文章准备专属 Discussion：#{discussion.number}
          </p>
        )}
      </div>
    </section>
  )
}
