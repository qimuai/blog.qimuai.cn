---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-10 pb-8", "border-b border-border"]}>
      <p class="text-xs tracking-[0.35em] text-accent/80 uppercase">
        blog.qimuai.cn
      </p>
      <div
        class="mt-5 grid gap-8 sm:grid-cols-[minmax(0,1.5fr)_minmax(220px,0.8fr)] sm:items-end"
      >
        <div>
          <h1
            class="max-w-3xl text-4xl leading-tight font-semibold sm:text-6xl"
          >
            把复杂问题写清楚，把真实经验留下来。
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-8 sm:text-lg">
            这里记录 AI 应用、自动化工作流、Web 工程和产品实践，
            重点不是概念，而是那些真正在线上跑通的细节。
          </p>
          <p class="mt-3 max-w-2xl text-base leading-8 text-foreground/80">
            如果一篇文章不能帮人少踩几个坑，它就还不值得发出来。
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <LinkButton href="/posts/">
              开始阅读
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
            <LinkButton href="/about/" class="opacity-80">
              了解这个博客
            </LinkButton>
          </div>
        </div>

        <aside
          class="border border-border bg-background/75 p-4 backdrop-blur-sm"
        >
          <div class="text-xs tracking-[0.3em] text-accent/80 uppercase">
            关注领域
          </div>
          <ul class="mt-3 space-y-2 text-sm leading-7 sm:text-base">
            <li>AI 工作流与工具链</li>
            <li>自动化部署与协作</li>
            <li>Web 工程与内容系统</li>
            <li>产品实践与复盘</li>
          </ul>
        </aside>
      </div>

      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
            <span class="tracking-[0.24em] text-accent/80 uppercase">
              相关链接
            </span>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">置顶文章</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">最新更新</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        查看全部文章
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
