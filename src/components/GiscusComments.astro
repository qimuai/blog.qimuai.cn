---
import { SITE } from "@/config";
import discussions from "@/data/discussions.json";

type Props = {
  pagePath: string;
  pageTitle: string;
  pageUrl: string;
};

const comments = SITE.comments;
const { pagePath, pageTitle, pageUrl } = Astro.props;
const discussionMap = discussions as Record<
  string,
  { number: number; title: string; url: string }
>;
const discussion = discussionMap[pagePath];
const discussionUrl =
  discussion?.url ??
  `https://github.com/${comments.repo}/discussions/new?category=general&title=${encodeURIComponent(
    `[ ${pagePath} ] ${pageTitle}`
  )}&body=${encodeURIComponent(
    `文章地址: ${pageUrl}\n\n欢迎继续补充案例、问题、勘误和后续实践。`
  )}`;
---

{
  comments.enabled && (
    <section
      class="mt-16 max-w-4xl border-t border-border/38 pt-6"
      data-pagefind-ignore
    >
      <div class="space-y-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <p class="text-[0.68rem] tracking-[0.28em] text-foreground/34 uppercase">
            评论
          </p>
          <div class="flex flex-wrap gap-4 text-sm text-foreground/40">
            <a
              href={discussionUrl}
              class="underline decoration-dashed underline-offset-4 hover:text-accent"
            >
              {discussion ? "查看讨论" : "创建讨论"}
            </a>
            <a
              href={`https://github.com/${comments.repo}/discussions`}
              class="underline decoration-dashed underline-offset-4 hover:text-accent"
            >
              全部讨论
            </a>
          </div>
        </div>

        <div
          id="giscus-thread"
          class="min-h-40"
          data-discussion-url={discussionUrl}
        >
          <div class="text-sm leading-7 text-foreground/40">评论加载中...</div>
        </div>

        {discussion && (
          <p class="text-xs leading-6 text-foreground/30">
            当前文章已关联到 Discussion #{discussion.number}
          </p>
        )}
      </div>
    </section>
  )
}

<script
  is:inline
  data-astro-rerun
  define:vars={{
    repo: comments.repo,
    repoId: comments.repoId,
    category: comments.category,
    categoryId: comments.categoryId,
    mapping: comments.mapping,
    strict: comments.strict,
    reactionsEnabled: comments.reactionsEnabled,
    emitMetadata: comments.emitMetadata,
    inputPosition: comments.inputPosition,
    lang: comments.lang,
  }}
>
  const THREAD_ID = "giscus-thread";

  function getGiscusTheme() {
    return document.documentElement.getAttribute("data-theme") === "dark"
      ? "dark_dimmed"
      : "light";
  }

  function renderGiscus() {
    const container = document.getElementById(THREAD_ID);
    if (!container) return;

    container.innerHTML = "";

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.async = true;
    script.crossOrigin = "anonymous";
    script.setAttribute("data-repo", repo);
    script.setAttribute("data-repo-id", repoId);
    script.setAttribute("data-category", category);
    script.setAttribute("data-category-id", categoryId);
    script.setAttribute("data-mapping", mapping);
    script.setAttribute("data-strict", strict);
    script.setAttribute("data-reactions-enabled", reactionsEnabled);
    script.setAttribute("data-emit-metadata", emitMetadata);
    script.setAttribute("data-input-position", inputPosition);
    script.setAttribute("data-lang", lang);
    script.setAttribute("data-theme", getGiscusTheme());
    container.appendChild(script);
  }

  function syncGiscusTheme() {
    const iframe = document.querySelector("iframe.giscus-frame");
    if (!iframe || !iframe.contentWindow) return;

    iframe.contentWindow.postMessage(
      {
        giscus: {
          setConfig: {
            theme: getGiscusTheme(),
          },
        },
      },
      "https://giscus.app"
    );
  }

  function bootGiscus() {
    renderGiscus();
    window.setTimeout(syncGiscusTheme, 350);
  }

  bootGiscus();
  document.addEventListener("astro:page-load", bootGiscus);
  document.addEventListener("theme-changed", syncGiscusTheme);
</script>
