---
type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  headings: Heading[];
};

const { headings } = Astro.props;
const toc = headings.filter(({ depth }) => depth >= 2 && depth <= 3);
---

{
  toc.length > 0 && (
    <nav aria-label="文章目录" class="paper-panel p-5">
      <p class="section-kicker">目录</p>
      <ol class="mt-4 space-y-3 text-sm leading-6 text-foreground/72">
        {toc.map(heading => (
          <li class:list={[heading.depth > 2 && "ps-4"]}>
            <a
              href={`#${heading.slug}`}
              class="block transition-colors hover:text-accent"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
